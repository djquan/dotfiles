alias ll='eza -alh'
alias l='eza -lh'

alias cdc='cd ~/code'

alias ghist='git hist'
alias g='git'
alias gd='git diff'
alias gds='git diff --staged'
alias gst='git status'
alias gp='git push'
alias gpl='git pull'
alias ga='git add -v'
alias gcmsg='git commit -m'

if hash batcat 2>/dev/null; then
  alias bat='batcat'
fi

alias fzfp="fzf --preview 'bat --style=numbers --color=always --line-range :500 {}'"
alias vim="nvim"

alias ccusage='npx ccusage@latest'
alias brexctl='TERM=xterm-256color brexctl'

alias c='claude'
alias ch='claude --chrome'

vibe() {
  local desc="vibe pre-claude $(date +%Y-%m-%d_%H:%M:%S)"
  local root_snap home_snap
  root_snap=$(sudo snapper -c root create --description "$desc" --print-number) || return 1
  home_snap=$(sudo snapper -c home create --description "$desc" --print-number) || return 1
  echo "snapshots: root=#${root_snap}  home=#${home_snap}  ($desc)"
  echo "  rollback home:  sudo snapper -c home undochange ${home_snap}..0"
  echo "  rollback root:  sudo snapper -c root rollback ${root_snap}   # then reboot"
  claude --dangerously-skip-permissions "$@"
}

alias lg='lazygit'


